# Elite Dangerous PIP management
# @ = trigger on key release, so all modifiers are already physically released
# when xdotool runs, avoiding stuck-modifier bugs

# Dodge mode : 0.5SYS / 4ENG / 1.5WEP
@F1
    $MACROS_DIR/pip.sh dodge

# Flee mode : 2SYS / 4ENG / 0WEP
@ctrl + F1
    $MACROS_DIR/pip.sh flee

# Combat mode : 0.5SYS / 1.5ENG / 4WEP
@F2
    $MACROS_DIR/pip.sh combat

# Combat2 mode : -SYS / 2ENG / 4WEP
@ctrl + F2
    $MACROS_DIR/pip.sh combat2

# Pursuit mode : 2SYS / 1ENG / 3WEP
@F3
    $MACROS_DIR/pip.sh pursuit

# Offense mode : 3SYS / -ENG / 3WEP
@ctrl + F3
    $MACROS_DIR/pip.sh offense

# Shields mode : 4SYS / 2ENG / -WEP
@F4
    $MACROS_DIR/pip.sh shields

# Defense mode : 4SYS / -ENG / 2WEP
@ctrl + F4
    $MACROS_DIR/pip.sh defense
